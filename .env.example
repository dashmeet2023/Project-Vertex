# =============================================================================
# Project Vertex — Environment Configuration Example
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=vertex
POSTGRES_USER=vertex_app
POSTGRES_PASSWORD=changeme_dev

# Superuser used only for migrations / RLS setup
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=changeme_super

# --- Application DB roles (created by migration seed script) ---
APP_USER_PASSWORD=changeme_app_user
APP_ADMIN_PASSWORD=changeme_app_admin

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Token signing secrets (JSON map of kid → secret) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_SIGNING_KEYS={"v1":"replace_with_32_byte_hex_secret_v1"}
TOKEN_ACTIVE_KID=v1
TOKEN_TTL_SECONDS=600

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_TITLE=Project Vertex
